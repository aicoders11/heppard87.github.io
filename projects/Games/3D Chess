<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Chris Heppard's 3D Chess</title>
    <style>
        :root {
            --neon-cyan: #00ffff;
            --neon-magenta: #ff00ff;
            --glass-bg: rgba(5, 10, 20, 0.9);
            --panel-border: rgba(0, 255, 255, 0.2);
        }

        body { 
            margin: 0; 
            overflow: hidden; 
            background: #010105; 
            font-family: 'Segoe UI', system-ui, sans-serif; 
            color: white; 
            touch-action: none;
        }

        #ui-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none; z-index: 10;
        }

        .glass-panel {
            pointer-events: auto;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--panel-border);
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.9);
        }

        /* Top Header */
        #header {
            position: absolute; top: env(safe-area-inset-top, 20px); left: 20px; padding: 15px 25px;
            border-left: 4px solid var(--neon-cyan);
        }
        #header h1 { margin: 0; font-size: 18px; letter-spacing: 3px; text-transform: uppercase; color: var(--neon-cyan); }
        #header p { margin: 2px 0 0 0; font-size: 9px; opacity: 0.6; letter-spacing: 2px; }

        /* Turn Indicator */
        #turn-panel {
            position: absolute; top: env(safe-area-inset-top, 20px); right: 20px;
            padding: 15px 25px; text-align: right;
        }
        .turn-label { font-size: 9px; color: var(--neon-cyan); text-transform: uppercase; letter-spacing: 1px; }
        #current-turn { font-size: 20px; font-weight: bold; text-shadow: 0 0 10px var(--neon-cyan); transition: color 0.3s; }
        #current-turn.magenta { color: var(--neon-magenta); text-shadow: 0 0 10px var(--neon-magenta); }

        /* Captured Pieces Sidebar */
        #captured-panel {
            position: absolute; top: 110px; right: 20px; width: 100px; padding: 15px;
            display: flex; flex-direction: column; gap: 10px;
        }
        .captured-group { display: flex; flex-wrap: wrap; gap: 5px; opacity: 0.7; }

        /* HUD Footer */
        #hud-footer {
            position: absolute; bottom: env(safe-area-inset-bottom, 30px); left: 50%; transform: translateX(-50%);
            padding: 12px 30px; display: flex; gap: 40px;
        }
        .stat-group { text-align: center; }
        .stat-label { font-size: 9px; color: #888; text-transform: uppercase; margin-bottom: 2px; }
        .stat-value { font-size: 16px; font-weight: bold; color: #fff; }

        #toast {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: var(--neon-cyan); color: black; padding: 15px 40px; border-radius: 4px;
            font-weight: bold; font-size: 18px; opacity: 0; transition: opacity 0.4s;
            pointer-events: none; z-index: 100; text-transform: uppercase;
        }

        canvas { display: block; outline: none; }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
</head>
<body>

    <div id="toast">CHECKMATE</div>

    <div id="ui-overlay">
        <div id="header" class="glass-panel">
            <h1>3D CHESS</h1>
            <p>HEPPARD LOGIC SIMULATOR v4.2</p>
        </div>

        <div id="turn-panel" class="glass-panel">
            <div class="turn-label">Current Strategy</div>
            <div id="current-turn">CYAN TURN</div>
        </div>

        <div id="captured-panel" class="glass-panel">
            <div class="turn-label" style="text-align: center; margin-bottom: 5px;">Recycled</div>
            <div id="captured-cyan" class="captured-group"></div>
            <div id="captured-magenta" class="captured-group" style="margin-top: 10px; border-top: 1px solid rgba(255,0,255,0.2); padding-top: 10px;"></div>
        </div>

        <div id="hud-footer" class="glass-panel">
            <div class="stat-group">
                <div class="stat-label">Neural Sync</div>
                <div id="sync-val" class="stat-value">CONNECTED</div>
            </div>
            <div class="stat-group">
                <div class="stat-label">System State</div>
                <div class="stat-value" style="color: var(--neon-cyan);">STABLE</div>
            </div>
            <button class="stat-group" onclick="location.reload()" style="background:none; border:none; cursor:pointer; pointer-events:auto;">
                <div class="stat-label">Reset</div>
                <div class="stat-value" style="color: var(--neon-magenta);">REBOOT</div>
            </button>
        </div>
    </div>

    <script>
        // --- CHESS ENGINE CONSTANTS ---
        const TILE_SIZE = 50;
        const BOARD_SIZE = 8;
        const COLORS = {
            cyan: 0x00ffff,
            magenta: 0xff00ff,
            tileA: 0x050510,
            tileB: 0x0a0a20,
            highlight: 0x00ff00
        };

        // --- APP STATE ---
        let scene, camera, renderer, controls, raycaster, mouse;
        let board = [], pieces = [], highlights = [];
        let turn = 'cyan'; // 'cyan' or 'magenta'
        let selectedPiece = null;
        let moveTargets = [];

        // Interaction timing for touch
        let pTime = 0, pStart = new THREE.Vector2();

        init();
        setupBoard();
        animate();

        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x010105);
            scene.fog = new THREE.FogExp2(0x010105, 0.002);

            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 1, 10000);
            camera.position.set(0, 500, 600);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.setSize(window.innerWidth, window.innerHeight);
            document.body.appendChild(renderer.domElement);

            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.maxPolarAngle = Math.PI / 2.1;
            controls.minDistance = 300;
            controls.maxDistance = 1500;

            raycaster = new THREE.Raycaster();
            mouse = new THREE.Vector2();

            // Lights
            scene.add(new THREE.AmbientLight(0x404040));
            const l1 = new THREE.PointLight(0xffffff, 1, 2000);
            l1.position.set(0, 500, 0);
            scene.add(l1);

            // Reflective Table
            const tGeo = new THREE.PlaneGeometry(2000, 2000);
            const tMat = new THREE.MeshStandardMaterial({ color: 0x020205, roughness: 0.1, metalness: 0.5 });
            const table = new THREE.Mesh(tGeo, tMat);
            table.rotation.x = -Math.PI / 2;
            table.position.y = -5;
            scene.add(table);

            // Listeners
            window.addEventListener('pointerdown', e => { pTime = Date.now(); pStart.set(e.clientX, e.clientY); });
            window.addEventListener('pointerup', onPointerUp);
            window.addEventListener('resize', onWindowResize);
        }

        function setupBoard() {
            const boardGroup = new THREE.Group();
            for (let r = 0; r < BOARD_SIZE; r++) {
                board[r] = [];
                for (let c = 0; c < BOARD_SIZE; c++) {
                    const isDark = (r + c) % 2 === 1;
                    const tile = createTile(isDark, r, c);
                    boardGroup.add(tile);
                    board[r][c] = { tile, piece: null };
                }
            }
            scene.add(boardGroup);

            // Initial Layout
            const layout = ['rook', 'knight', 'bishop', 'queen', 'king', 'bishop', 'knight', 'rook'];
            
            // Cyan Pieces (White)
            for (let i = 0; i < 8; i++) {
                spawnPiece('pawn', 'cyan', 1, i);
                spawnPiece(layout[i], 'cyan', 0, i);
            }
            // Magenta Pieces (Black)
            for (let i = 0; i < 8; i++) {
                spawnPiece('pawn', 'magenta', 6, i);
                spawnPiece(layout[i], 'magenta', 7, i);
            }
        }

        function createTile(isDark, r, c) {
            const geo = new THREE.BoxGeometry(TILE_SIZE, 10, TILE_SIZE);
            const mat = new THREE.MeshStandardMaterial({ 
                color: isDark ? COLORS.tileA : COLORS.tileB,
                emissive: isDark ? 0x000000 : 0x000011,
                roughness: 0.2
            });
            const tile = new THREE.Mesh(geo, mat);
            tile.position.set((c - 3.5) * TILE_SIZE, 0, (r - 3.5) * TILE_SIZE);
            tile.userData = { r, c, type: 'tile' };
            return tile;
        }

        function spawnPiece(type, color, r, c) {
            let geo;
            const s = 18;
            switch(type) {
                case 'pawn': geo = new THREE.ConeGeometry(s/2, s*1.5, 12); break;
                case 'rook': geo = new THREE.BoxGeometry(s, s*2, s); break;
                case 'knight': geo = new THREE.TorusKnotGeometry(s/3, 4, 32, 8); break;
                case 'bishop': geo = new THREE.CapsuleGeometry(s/3, s, 4, 8); break;
                case 'queen': geo = new THREE.OctahedronGeometry(s, 0); break;
                case 'king': geo = new THREE.CylinderGeometry(s/2, s/2, s*2.5, 12); break;
            }

            const mat = new THREE.MeshStandardMaterial({
                color: COLORS[color],
                emissive: COLORS[color],
                emissiveIntensity: 0.5,
                metalness: 0.8,
                roughness: 0.1
            });

            const mesh = new THREE.Mesh(geo, mat);
            mesh.position.set((c - 3.5) * TILE_SIZE, 20, (r - 3.5) * TILE_SIZE);
            mesh.userData = { type, color, r, c, active: true };
            
            scene.add(mesh);
            pieces.push(mesh);
            board[r][c].piece = mesh;
        }

        function onPointerUp(e) {
            if (Date.now() - pTime > 250 || pStart.distanceTo(new THREE.Vector2(e.clientX, e.clientY)) > 10) return;

            mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const hits = raycaster.intersectObjects(scene.children);

            if (hits.length > 0) {
                const obj = hits[0].object;
                
                // Clicking a Move Target (Highlight Dot)
                if (obj.userData.isTarget) {
                    movePiece(selectedPiece, obj.userData.r, obj.userData.c);
                    return;
                }

                // Clicking a Piece
                const hitPiece = pieces.find(p => p === obj);
                if (hitPiece && hitPiece.userData.color === turn) {
                    selectPiece(hitPiece);
                } else if (selectedPiece && (obj.userData.type === 'tile' || (hitPiece && hitPiece.userData.color !== turn))) {
                    // Try to move to the tile or the enemy piece position
                    const target = hitPiece ? hitPiece.userData : obj.userData;
                    const canMove = moveTargets.some(t => t.r === target.r && t.c === target.c);
                    if (canMove) movePiece(selectedPiece, target.r, target.c);
                    else deselect();
                } else {
                    deselect();
                }
            }
        }

        function selectPiece(p) {
            deselect();
            selectedPiece = p;
            p.material.emissiveIntensity = 2.0;
            
            // Logic: Calculate valid moves (Simplified for Demo)
            calculateMoves(p);
            showHighlights();
        }

        function deselect() {
            if (selectedPiece) selectedPiece.material.emissiveIntensity = 0.5;
            selectedPiece = null;
            clearHighlights();
        }

        function calculateMoves(p) {
            moveTargets = [];
            const { r, c, type, color } = p.userData;
            const dir = color === 'cyan' ? 1 : -1;

            // Simple Logic Helpers
            const onBoard = (row, col) => row >= 0 && row < 8 && col >= 0 && col < 8;
            const getAt = (row, col) => onBoard(row, col) ? board[row][col].piece : null;
            
            const addMove = (row, col) => {
                if (!onBoard(row, col)) return false;
                const occupant = getAt(row, col);
                if (!occupant) {
                    moveTargets.push({ r: row, c: col });
                    return true;
                } else if (occupant.userData.color !== color) {
                    moveTargets.push({ r: row, c: col });
                    return false;
                }
                return false;
            };

            if (type === 'pawn') {
                if (!getAt(r + dir, c)) {
                    addMove(r + dir, c);
                    if ((color === 'cyan' && r === 1 || color === 'magenta' && r === 6) && !getAt(r + dir * 2, c)) {
                        addMove(r + dir * 2, c);
                    }
                }
                // Captures
                const left = getAt(r + dir, c - 1);
                const right = getAt(r + dir, c + 1);
                if (left && left.userData.color !== color) moveTargets.push({ r: r + dir, c: c - 1 });
                if (right && right.userData.color !== color) moveTargets.push({ r: r + dir, c: c + 1 });
            } 
            else if (type === 'knight') {
                const jumps = [[2,1],[2,-1],[-2,1],[-2,-1],[1,2],[1,-2],[-1,2],[-1,-2]];
                jumps.forEach(j => addMove(r + j[0], c + j[1]));
            }
            else if (type === 'rook' || type === 'queen') {
                [[0,1],[0,-1],[1,0],[-1,0]].forEach(d => {
                    for(let i=1; i<8; i++) { if(!addMove(r + d[0]*i, c + d[1]*i)) break; }
                });
            }
            if (type === 'bishop' || type === 'queen') {
                [[1,1],[1,-1],[-1,1],[-1,-1]].forEach(d => {
                    for(let i=1; i<8; i++) { if(!addMove(r + d[0]*i, c + d[1]*i)) break; }
                });
            }
            if (type === 'king') {
                for(let x=-1; x<=1; x++) for(let y=-1; y<=1; y++) if(x!==0||y!==0) addMove(r+x, c+y);
            }
        }

        function showHighlights() {
            moveTargets.forEach(m => {
                const dot = new THREE.Mesh(
                    new THREE.CircleGeometry(8, 16),
                    new THREE.MeshBasicMaterial({ color: COLORS.highlight, transparent: true, opacity: 0.6 })
                );
                dot.rotation.x = -Math.PI / 2;
                dot.position.set((m.c - 3.5) * TILE_SIZE, 6, (m.r - 3.5) * TILE_SIZE);
                dot.userData = { isTarget: true, r: m.r, c: m.c };
                scene.add(dot);
                highlights.push(dot);
            });
        }

        function clearHighlights() {
            highlights.forEach(h => scene.remove(h));
            highlights = [];
        }

        function movePiece(p, nr, nc) {
            const or = p.userData.r;
            const oc = p.userData.c;

            // Capture Enemy
            const target = board[nr][nc].piece;
            if (target) {
                target.userData.active = false;
                scene.remove(target);
                addCaptured(target.userData.type, target.userData.color);
                if (target.userData.type === 'king') showToast(`${turn} wins`);
            }

            // Logic Swap
            board[or][oc].piece = null;
            board[nr][nc].piece = p;
            p.userData.r = nr;
            p.userData.c = nc;

            // Visual Slide (Animated)
            const targetPos = new THREE.Vector3((nc - 3.5) * TILE_SIZE, 20, (nr - 3.5) * TILE_SIZE);
            p.userData.targetPos = targetPos;

            deselect();
            turn = turn === 'cyan' ? 'magenta' : 'cyan';
            updateTurnUI();
        }

        function updateTurnUI() {
            const el = document.getElementById('current-turn');
            el.innerText = `${turn.toUpperCase()} STRATEGY`;
            el.className = turn === 'magenta' ? 'magenta' : '';
        }

        function addCaptured(type, color) {
            const container = document.getElementById(`captured-${color}`);
            const pieceChar = { pawn: '♙', rook: '♖', knight: '♘', bishop: '♗', queen: '♕', king: '♔' };
            const span = document.createElement('span');
            span.innerText = pieceChar[type] || '•';
            span.style.fontSize = '20px';
            span.style.color = COLORS[color === 'cyan' ? 'cyan' : 'magenta'];
            container.appendChild(span);
        }

        function showToast(msg) {
            const t = document.getElementById('toast');
            t.innerText = msg; t.style.opacity = 1;
            setTimeout(() => t.style.opacity = 0, 3000);
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            controls.update();

            // Smooth Interpolation for moves
            pieces.forEach(p => {
                if (p.userData.targetPos) {
                    p.position.lerp(p.userData.targetPos, 0.15);
                    if (p.position.distanceTo(p.userData.targetPos) < 0.1) {
                        p.position.copy(p.userData.targetPos);
                        delete p.userData.targetPos;
                    }
                }
                // Idle Glow animation
                if (p.userData.active) {
                    const pulse = 0.5 + Math.sin(Date.now() * 0.002) * 0.2;
                    p.material.emissiveIntensity = p === selectedPiece ? 2.0 : pulse;
                }
            });

            renderer.render(scene, camera);
        }
    </script>
</body>
</html>
